# Spotify
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://your-app.onrender.com/callback

# Session (обязательно поменяй на случайную строку!)
SESSION_SECRET=replace-with-long-random-string-min-32-chars

# Окружение (важно для Render — включает secure cookies)
NODE_ENV=production

# Last.fm (получи бесплатно на https://www.last.fm/api/account/create)
LASTFM_API_KEY=your_lastfm_api_key
